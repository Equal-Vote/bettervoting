# GitHub Issue Management - Sample Environment Configuration
# Copy this file to .env and fill in your actual values

##### GITHUB AUTHENTICATION #####
# Create a Personal Access Token at: https://github.com/settings/tokens
# Required scopes: 'repo' (for private repos) or 'public_repo' (for public repos)
GITHUB_TOKEN=ghp_your_personal_access_token_here

##### REPOSITORY CONFIGURATION #####
# Format: owner/repo (e.g., recursivesquircle/star-server)
GITHUB_REPOSITORY=owner/repo

##### SCRIPT BEHAVIOR #####
# Set to 'true' to preview actions without making changes
# Set to 'false' to actually post comments and apply labels
DRY_RUN=true

##### TIMEFRAME CONFIGURATION #####
# Time unit for thresholds: 'weeks', 'minutes', or 'seconds'
# Use 'weeks' for production, 'seconds' or 'minutes' for testing
TIME_UNIT=weeks

# Threshold for posting a warning comment (in TIME_UNIT)
# Default: 1 week for production
WARNING_WEEKS=1

# Threshold for applying "2 weeks inactive" label (in TIME_UNIT)
# Default: 2 weeks for production
INACTIVE_WEEKS=2

